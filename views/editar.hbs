<h1>Editar Articulo</h1>
<form action="/articulos/{{EditArtic.id}}/editar" method="post">
    <input type="text" name="titulo" placeholder="titulo" value="{{EditArtic.titulo}}">
    <input type="text" name="contenido" placeholder="contenido" value="{{EditArtic.contenido}}">
    <input type="text" name="categoria" placeholder="categoria" value="{{EditArtic.categoria}}">
    <button type="submit">Guardar</button>
</form>